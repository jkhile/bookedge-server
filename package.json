{
  "name": "bookedge-server",
  "description": "Server component of the FEP BookEdge system",
  "version": "1.7.0",
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67",
  "homepage": "",
  "private": true,
  "keywords": [
    "feathers",
    "bookedge"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkhile/bookedge-server.git"
  },
  "author": {
    "name": "John Hile",
    "email": "john.hile@frontedgepublishing.com"
  },
  "contributors": [
    "dmitri.barvinok@frontedgepublishing.com"
  ],
  "bugs": {},
  "engines": {
    "node": "20.x"
  },
  "feathers": {
    "language": "ts",
    "packager": "pnpm",
    "database": "postgresql",
    "framework": "koa",
    "transports": [
      "rest",
      "websockets"
    ],
    "schema": "typebox"
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "files": [
    "lib/client.js",
    "lib/**/*.d.ts",
    "lib/**/*.shared.js"
  ],
  "main": "lib/client",
  "scripts": {
    "check": "pnpm prettier && pnpm lint && pnpm compile",
    "dev": "dotenvx run --env-file=.env -- nodemon  -x tsx src/index.ts",
    "dev:test": "pnpm make-test-db && dotenvx run --env-file=.env.test -- nodemon -x tsx src/index",
    "reset-log": "cp ./reset.log ./debug-development.log && echo \"Log reset\"",
    "lint": "eslint ./src",
    "compile": "shx rm -rf lib/ && tsc",
    "build": "pnpm compile",
    "start": "node lib/",
    "prettier": "pnpm exec prettier \"**/*.ts\" --write --log-level warn",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "test:ui": "cross-env NODE_ENV=test vitest --ui",
    "bundle:client": "pnpm run compile && pnpm pack --pack-destination ./public",
    "pull-db": "./scripts/pulldb.zsh",
    "reset-db": "dropdb bookedge-server --if-exists && createdb bookedge-server && pnpm migrate && ./scripts/load-db-fixtures.zsh && pnpm make-test-db",
    "make-test-db": "./scripts/setup-test-server.zsh && psql --dbname=bookedge-test --file=insert-test-users.sql",
    "migrate": "dotenvx run -- knex migrate:latest",
    "migrate:down": "dotenvx run -- knex migrate:down",
    "migrate:make": "knex migrate:make",
    "import-authors": "tsx src/scripts/import-author-contacts.ts",
    "test-parser": "tsx src/scripts/test-parser.ts",
    "cleanup-tokens": "tsx src/scripts/cleanup-refresh-tokens.ts",
    "backup-heroku-db": "tsx src/scripts/backup-heroku-db.ts",
    "restore-heroku-db": "tsx src/scripts/restore-heroku-db.ts",
    "update-revenue-splits": "tsx src/scripts/update-revenue-splits.ts"
  },
  "dependencies": {
    "@feathersjs/adapter-commons": "^5.0.43",
    "@feathersjs/authentication": "^5.0.43",
    "@feathersjs/authentication-client": "^5.0.43",
    "@feathersjs/authentication-local": "^5.0.43",
    "@feathersjs/authentication-oauth": "^5.0.43",
    "@feathersjs/configuration": "^5.0.43",
    "@feathersjs/errors": "^5.0.43",
    "@feathersjs/feathers": "^5.0.43",
    "@feathersjs/knex": "^5.0.43",
    "@feathersjs/koa": "^5.0.43",
    "@feathersjs/rest-client": "^5.0.43",
    "@feathersjs/schema": "^5.0.43",
    "@feathersjs/socketio": "^5.0.43",
    "@feathersjs/transport-commons": "^5.0.43",
    "@feathersjs/typebox": "^5.0.43",
    "axios": "^1.14.0",
    "coralogix-logger": "^1.2.2",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "fs-extra": "^11.3.4",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "just-diff": "^6.0.2",
    "knex": "^3.2.8",
    "lodash": "^4.17.23",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pretty-format": "^30.3.0",
    "sharp": "^0.34.5",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@feathersjs/cli": "5.0.43",
    "@types/debug": "^4.1.13",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa": "^3.0.2",
    "@types/koa__multer": "^2.0.8",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "json5": "^2.2.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "es5-ext",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "config": "4.1.1"
    }
  }
}
